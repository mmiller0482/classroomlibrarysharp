<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ClassroomLibrary.App"
             Name="Classroom Library"
             RequestedThemeVariant="Default">
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="Settings…"
                            Gesture="Meta+OemComma"
                            Click="Settings_OnClick" />
        </NativeMenu>
    </NativeMenu.Menu>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://ClassroomLibrary/Themes/ClassroomTheme.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource ClassroomBackgroundBrush}" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource ClassroomSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ClassroomBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style Selector="TextBlock.secondary">
            <Setter Property="Foreground" Value="{DynamicResource ClassroomMutedForegroundBrush}" />
        </Style>
    </Application.Styles>
</Application>
