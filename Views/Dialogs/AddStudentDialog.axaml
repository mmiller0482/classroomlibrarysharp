<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ClassroomLibrary.Views.Dialogs.AddStudentDialog"
        Title="Add Student"
        Width="360" Height="300"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <DockPanel Margin="16">

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button Content="Add Student" Click="OnAddClick" IsDefault="True" />
            <Button Content="Cancel"      Click="OnCancelClick" IsCancel="True" />
        </StackPanel>

        <!-- Form -->
        <StackPanel Spacing="10">

            <StackPanel Spacing="8">
                <TextBlock Text="Name *"
                           FontWeight="SemiBold" />
                <TextBox x:Name="NameBox" />

                <TextBlock Text="Grade" FontWeight="SemiBold" />
                <TextBox x:Name="GradeBox"
                         Watermark="e.g. 3rd, 4th, 5th …" />
                
                <TextBlock Text="Homeroom Teacher"
                           FontWeight="SemiBold" />
                <TextBox x:Name="TeacherBox"
                         Watermark="Mrs. Miller" />
                
                <TextBlock x:Name="ErrorBox"
                           IsVisible="False"
                           Foreground="Red"
                           TextWrapping="Wrap"
                           FontWeight="SemiBold"
                           Margin="0,4,0,0" />
            </StackPanel>

        </StackPanel>
    </DockPanel>
</Window>
